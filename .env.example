# Copy to .env.local in the project root (next to package.json), then restart: npm run dev
#
# --- This app (Postgres via `pg`) ---
# Use Connect → Session pooler → URI. User looks like postgres.YOUR_PROJECT_REF (not plain postgres).
# Host must be *.pooler.supabase.com (not db.*.supabase.co on IPv4-only networks).
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
#
# If the subdomain in the dashboard is YOUR_REF, then YOUR_PROJECT_REF in the URI is the same string.
# If you get "self-signed certificate in certificate chain", add:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
#
# --- Not used by this repo unless you add @supabase/supabase-js ---
# The Supabase dashboard "Framework" Connect tab shows NEXT_PUBLIC_SUPABASE_URL + publishable key.
# Those are for the JS client (Auth/Realtime/browser), NOT a substitute for DATABASE_URL above.
# On Vercel with Supabase *session* pooler (~15 connections total), keep this low (default is 2 on Vercel).
# DATABASE_POOL_MAX=2
#
# --- Admin panel (/admin, secret corner control on main site) ---
# ADMIN_PASSWORD=your-strong-password
# Optional: improves cookie signing if set (openssl rand -hex 32)
# ADMIN_SESSION_SECRET=
#
# --- DB migrations (Supabase SQL editor, in order) ---
# db/migrations/001 … 005_calibration_app_settings.sql (default owner on tracker; optional)

DATABASE_URL=
